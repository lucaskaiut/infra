DOMAIN=noxagenda.com.br
APP_NAME="Nox Scheduler"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.noxagenda.com.br

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=nox_scheduler
DB_USERNAME=nox_scheduler
DB_PASSWORD=altere_para_a_senha_do_usuario_mysql_desta_app

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

CACHE_STORE=redis
QUEUE_CONNECTION=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_PREFIX=nox_scheduler_

TELESCOPE_ENABLED=false

SANCTUM_STATEFUL_DOMAINS=api.noxagenda.com.br

MAIL_MAILER=log
