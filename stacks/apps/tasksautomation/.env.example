DOMAIN=lucaskaiut.com.br
APP_NAME=TasksAutomation
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://tasksautomation.lucaskaiut.com.br

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=tasksautomation
DB_USERNAME=tasksautomation
DB_PASSWORD=defina_igual_ao_utilizador_MySQL_criado_para_esta_app

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

CACHE_STORE=redis
QUEUE_CONNECTION=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_PREFIX=tasksautomation_

# PHP-FPM/workers → TCP bridge (serviço Docker "websocket", porta 8082). Não use 127.0.0.1 aqui:
# o Nginx proxy de /ws/tasks para websocket:8081 pode funcionar mesmo quando isto está errado.
TASKS_REALTIME_BRIDGE_HOST=websocket
TASKS_REALTIME_BRIDGE_PORT=8082
TASKS_REALTIME_WS_PATH=/ws/tasks
TASKS_REALTIME_TOKEN_TTL_SECONDS=28800

MAIL_MAILER=log
