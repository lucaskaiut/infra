name: CI

on:
  push:
    branches: [main]
  pull_request:

jobs:
  tests:
    runs-on: ubuntu-latest
    services:
      mysql:
        image: mysql:8.4
        env:
          MYSQL_ROOT_PASSWORD: root
          MYSQL_DATABASE: tasksautomation_test
        ports:
          - 3306:3306
        options: >-
          --health-cmd "mysqladmin ping -h 127.0.0.1 -uroot -proot"
          --health-interval 5s
          --health-timeout 5s
          --health-retries 10
    steps:
      - uses: actions/checkout@v4
      - uses: shivammathur/setup-php@v2
        with:
          php-version: '8.3'
          extensions: mbstring, pdo_mysql, bcmath, intl, zip, redis
          coverage: none
      - uses: actions/setup-node@v4
        with:
          node-version: '22'
      - name: Composer
        run: composer install --no-interaction --prefer-dist
      - name: NPM
        run: npm ci || npm install
      - name: Build assets
        run: npm run build
      - name: App key
        run: php -r "file_exists('.env') || copy('.env.example', '.env');"
      - name: Generate key
        run: php artisan key:generate --force
      - name: Migrate
        run: php artisan migrate --force
      - name: PHPUnit
        run: php artisan test
        env:
          DB_CONNECTION: mysql
          DB_HOST: 127.0.0.1
          DB_PORT: 3306
          DB_DATABASE: tasksautomation_test
          DB_USERNAME: root
          DB_PASSWORD: root
