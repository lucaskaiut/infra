// Modelo para job "deploy-app" (Pipeline from SCM ou copiar para o Jenkins).
// Inclui notificação opcional ao n8n após o deploy (sucesso ou falha).
// Requisitos: N8N_DEPLOY_WEBHOOK_URL ou N8N_API_URL no .env do Jenkins / infra montado;
// imagem Jenkins com python3 (ver stacks/jenkins/image/Dockerfile).

pipeline {
  agent any
  parameters {
    string(name: 'APP_SLUG', defaultValue: 'meu-slug', description: 'Slug com ficheiro ci/apps/<slug>.sh')
  }
  stages {
    stage('Deploy') {
      steps {
        writeFile file: "${env.WORKSPACE}/.jenkins-notify-commits.json", text: '[]'
        sh """
          set -euo pipefail
          cd /infra-deploy
          INFRA_BEFORE=\$(git rev-parse HEAD)
          git pull origin main
          INFRA_AFTER=\$(git rev-parse HEAD)
          echo "\${INFRA_BEFORE}..\${INFRA_AFTER}" > "${env.WORKSPACE}/.jenkins-notify-infra-range.txt"
          export APP_SLUG='${params.APP_SLUG}'
          export NOTIFY_APP_SLUG="\${APP_SLUG}"
          export COMMITS_PAYLOAD_FILE="${env.WORKSPACE}/.jenkins-notify-commits.json"
          ./ci/deploy-app.sh ${params.APP_SLUG}
        """
      }
      post {
        always {
          script {
            env.NOTIFY_BUILD_RESULT = currentBuild.currentResult ?: 'FAILURE'
          }
          sh """
            set -eu
            export INFRA_ROOT=/infra-deploy
            export APP_SLUG='${params.APP_SLUG}'
            export NOTIFY_APP_SLUG='${params.APP_SLUG}'
            export NOTIFY_BUILD_RESULT='${env.NOTIFY_BUILD_RESULT}'
            export COMMITS_PAYLOAD_FILE='${env.WORKSPACE}/.jenkins-notify-commits.json'
            RFILE='${env.WORKSPACE}/.jenkins-notify-infra-range.txt'
            if [ -f "\$RFILE" ]; then
              export NOTIFY_INFRA_GIT_RANGE="\$(cat "\$RFILE")"
            fi
            /infra-deploy/ci/notify-n8n-deploy.sh || true
          """
        }
      }
    }
  }
}
